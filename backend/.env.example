# ═══════════════════════════════════════════════════════════════════════════════
# Sentinel-2 Dashboard — Backend Environment Variables
# Copy this file to .env and fill in your credentials.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Sentinel Hub (https://www.sentinel-hub.com/) ──────────────────────────────
# Free tier: 30,000 processing units/month
# Create an OAuth client at: Dashboard → User Settings → OAuth clients
SENTINELHUB_CLIENT_ID=your-client-id-here
SENTINELHUB_CLIENT_SECRET=your-client-secret-here
SENTINELHUB_INSTANCE_ID=your-instance-id-here

# ── Copernicus Dataspace (free, no account needed for STAC search) ────────────
# Full access requires registration at https://dataspace.copernicus.eu/
# COPERNICUS_CLIENT_ID=cdse-public

# ── Google Earth Engine (optional alternative backend) ───────────────────────
# USE_GEE=false
# GEE_SERVICE_ACCOUNT=my-account@project.iam.gserviceaccount.com
# GEE_KEY_FILE=/path/to/service-account-key.json

# ── Application settings ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","https://your-app.vercel.app"]
CACHE_TTL_SECONDS=3600
MAX_AOI_AREA_KM2=5000
DEFAULT_CLOUD_COVER=30
TILE_CACHE_DIR=/tmp/sentinel_tile_cache
